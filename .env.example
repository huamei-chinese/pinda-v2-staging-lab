DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
PORT=3000
NODE_ENV=production
ENABLE_DB_SCHEMA_INIT=true

SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret
SEPAY_BANK_NAME=your_bank_display_name
SEPAY_BANK_CODE=your_sepay_bank_code
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_ACCOUNT_NAME=your_bank_account_name
SEPAY_PAYMENT_PREFIX=HUAMEI

EMAIL_VERIFICATION_SECRET=your_email_verification_secret
EMAIL_FROM=HuaMei <no-reply@huamei.vn>
RESEND_API_KEY=your_resend_api_key

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_AVATAR_FOLDER=huamei/avatars

# Public CDN/Object Storage URLs. These values are exposed to the browser.
# Use these only for public static files such as audio, listening catalog, and images.
PUBLIC_CDN_BASE_URL=https://cdn.example.com
PUBLIC_ASSET_BASE_URL=https://cdn.example.com
PUBLIC_AUDIO_BASE_URL=https://cdn.example.com/audio
PUBLIC_LISTENING_APP_BASE_URL=https://cdn.example.com/listening-app
PUBLIC_LISTENING_CATALOG_JSON_URL=https://cdn.example.com/listening-app/data/listening-catalog.json
PUBLIC_LISTENING_CATALOG_SCRIPT_URL=https://cdn.example.com/listening-app/data/listening-catalog.js

OPENAI_API_KEY=your_openai_api_key
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=zh
OPENAI_ASSESSMENT_MODEL=gpt-4.1-mini
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-realtime-whisper
