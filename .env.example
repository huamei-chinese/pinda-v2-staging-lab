# Pinda V1 / HuaMei Learning App - environment template
# Do not put real secrets in this file.

# Runtime
NODE_ENV=production
# Official Node/Nest same-origin entry. 4173 was an old static preview port and should not be used for production backend deployment.
PORT=3000

# Database
# Required for login/account APIs, payment orders, subscriptions, admin APIs, and VIP activation.
# Static learning pages can still be served without this, but backend features will return errors.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Database schema initialization
# For MVP only: set to true once if the database tables have not been created yet.
# Turn off after initialization and use a migration process for production.
ENABLE_DB_SCHEMA_INIT=false

# Email verification
# Required in production if email verification is used. Never use a test value in production.
EMAIL_VERIFICATION_SECRET=replace_with_long_random_email_secret
EMAIL_FROM=HuaMei <no-reply@example.com>
RESEND_API_KEY=replace_with_resend_api_key_or_leave_empty_for_non_production

# SePay payment / VietQR
# Required to create real payment orders and auto-activate VIP after confirmed payment.
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
SEPAY_BANK_NAME=your_bank_display_name
SEPAY_BANK_CODE=your_sepay_bank_code
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_ACCOUNT_NAME=your_bank_account_name
SEPAY_PAYMENT_PREFIX=HUAMEI

# Cloudinary avatar upload
# Optional. Required only if avatar image upload is enabled.
CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret
CLOUDINARY_AVATAR_FOLDER=huamei/avatars

# Daily reminder emails
# Optional. Required only if scheduled reminder emails are enabled.
APP_URL=https://your-domain.example
REMINDER_EMAIL_FROM=HuaMei <onboarding@example.com>
REMINDER_EMAIL_REPLY_TO=support@example.com
