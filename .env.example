NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
ENABLE_DB_SCHEMA_INIT=true

# Firebase Authentication. The web API key is public configuration; the
# service-account email and private key must only be stored server-side.
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_AUTH_DOMAIN=your_firebase_project_id.firebaseapp.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_service_account_private_key\n-----END PRIVATE KEY-----\n"

# SePay payment integration. Keep placeholders here; set real values only in
# the deployment environment.
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
SEPAY_BANK_NAME=your_bank_display_name
SEPAY_BANK_CODE=your_sepay_bank_code
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_ACCOUNT_NAME=your_bank_account_name
SEPAY_PAYMENT_PREFIX=HUAMEI

PASSWORD_RESET_SECRET=replace_with_a_long_random_secret

EMAIL_FROM=HuaMei <no-reply@example.com>

# Railway/NestJS triggers the protected Netlify Background Function at 07:00 Vietnam time.
REMINDER_DISPATCH_ENABLED=false
REMINDER_DISPATCH_HOUR_VIETNAM=7
REMINDER_SERVICE_URL=https://your-reminder-site.netlify.app/.netlify/functions/daily-reminders-background
REMINDER_SERVICE_SECRET=replace_with_a_long_random_secret_shared_by_railway_and_netlify

# Password reset, email verification, and daily reminders use Gmail SMTP exclusively.
# Use a Google App Password, not the account password.
# SMTP_USER should match the email address inside SMTP_FROM.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password_without_spaces
SMTP_FROM=HuaMei <your_email@gmail.com>
