{
  "name": "luyenviet-nestjs",
  "version": "1.0.0",
  "description": "LuyenViet backend migrated to NestJS",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "generate:hsk2": "node ./scripts/generate-hsk2-content.mjs",
    "generate:high-frequency": "node ./scripts/generate-high-frequency-content.mjs",
    "generate:content": "npm run generate:hsk2 && npm run generate:hsk345",
    "generate:hsk345": "node ./scripts/generate-hsk345-content.mjs && node ./scripts/generate-aligned-early-content.mjs && node ./scripts/generate-aligned-next-content.mjs && node ./scripts/generate-aligned-final-content.mjs && node ./scripts/generate-hsk-remediation-content.mjs",
    "smoke:lab": "node ./scripts/smoke-staging-lab.mjs",
    "test": "node --test ./tests/*.test.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "pinyin-pro": "^3.28.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
